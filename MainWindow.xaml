<Window x:Class="VirtualPeto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pet" Height="150" Width="150"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Grid>
        <Image x:Name="PetImage" Stretch="Uniform"/>
        <MediaElement x:Name="PetVideo" Stretch="Uniform" LoadedBehavior="Manual" UnloadedBehavior="Stop" Visibility="Collapsed" MediaEnded="PetVideo_MediaEnded" IsMuted="True"/>
    </Grid>
</Window>