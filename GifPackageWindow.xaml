<Window x:Class="VirtualPeto.GifPackageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="clr-namespace:WpfAnimatedGif;assembly=WpfAnimatedGif"
        Title="Create New GIF Package (.vpet)" Height="450" Width="750"
        Background="#0F0F14" Foreground="White" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Create .vpet Package" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#4A90E2"/>

            <TextBlock Text="Pet Name:" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtName" Background="#1E1E24" Foreground="White" BorderBrush="#333" Padding="5" Margin="0,0,0,15"/>

            <TextBlock Text="GIF File:" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtGifPath" IsReadOnly="True" Background="#1E1E24" Foreground="#AAA" BorderBrush="#333" Padding="5"/>
                <Button Content="Browse..." Grid.Column="1" Click="BtnBrowseGif_Click" Width="80" Margin="5,0,0,0" Background="#2C2C3A" Foreground="White"/>
            </Grid>

            <TextBlock Text="Sound File (Optional):" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtSoundPath" IsReadOnly="True" Background="#1E1E24" Foreground="#AAA" BorderBrush="#333" Padding="5"/>
                <Button Content="Browse..." Grid.Column="1" Click="BtnBrowseSound_Click" Width="80" Margin="5,0,0,0" Background="#2C2C3A" Foreground="White"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,15" x:Name="SoundControls" Visibility="Collapsed">
                <Button Content="🔊 Play" Click="BtnPlaySound_Click" Background="#2C2C3A" Foreground="White" Padding="10,4" Margin="0,0,10,0"/>
                <TextBlock Text="Default Volume:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Slider x:Name="SldVolume" Width="120" Minimum="0" Maximum="1" Value="0.5" VerticalAlignment="Center" ValueChanged="SldVolume_ValueChanged"/>
                <TextBlock x:Name="TxtVolumeVal" Text="50%" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="#AAA"/>
            </StackPanel>

            <Button Content="📦 Build .vpet Package" Click="BtnBuild_Click" Background="#4A90E2" Foreground="White" FontWeight="Bold" Padding="15,10" Margin="0,10,0,0"/>
        </StackPanel>

        <Border Grid.Column="1" Background="#25252F"/>

        <Grid Grid.Column="2" Margin="20,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Live Preview" HorizontalAlignment="Center" FontWeight="Bold" Foreground="#AAA" Margin="0,0,0,10"/>
            <Border Grid.Row="1" Background="#16161F" CornerRadius="8" BorderBrush="#25252F" BorderThickness="1" Padding="10">
                <Image x:Name="ImgPreview" Stretch="Uniform" MaxHeight="250" MaxWidth="250" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>