<Window x:Class="VirtualPeto.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="clr-namespace:WpfAnimatedGif;assembly=WpfAnimatedGif"
        Title="VirtualPeto - Configuración" Height="600" Width="900"
        Background="#0F0F14" Foreground="White" WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl Background="Transparent" BorderBrush="Transparent">
            
            <TabItem Header="Library">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Tu Librería (Imágenes y Videos)" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSearchLibrary" TextChanged="TxtSearchLibrary_TextChanged" Background="#1A1A24" Foreground="White" Padding="5" BorderBrush="#333"/>
                            <Button Grid.Column="1" Content="+ Agregar desde PC" Click="BtnAddLibrary_Click" Background="#2C2C3A" Foreground="White" Padding="10,5" Margin="10,0,0,0"/>
                        </Grid>
                        <ListBox x:Name="LstLibrary" Grid.Row="2" Background="#1A1A24" BorderBrush="#333" Foreground="White" SelectionChanged="LstLibrary_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <TextBlock Text="🎥" Visibility="{Binding VideoIconVisibility}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <Image Source="{Binding Thumbnail}" Width="40" Height="40" Margin="0,0,10,0" Visibility="{Binding ImageIconVisibility}"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <Ellipse Width="10" Height="10" Fill="Lime" Margin="10,0,0,0" Visibility="{Binding VisibilityIndicator}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Border Grid.Column="1" Background="#1A1A24" CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock x:Name="TxtSelectedLibraryName" Text="Ninguna seleccionada" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,10"/>
                            <Border Height="150" Background="Black" Margin="0,0,0,15">
                                <Grid>
                                    <TextBlock x:Name="TxtEmptyLibraryPreview" Text="Sin vista previa" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                                    <Image x:Name="ImgLibraryPreview" Stretch="Uniform"/>
                                    <MediaElement x:Name="VidLibraryPreview" Stretch="Uniform" LoadedBehavior="Manual" UnloadedBehavior="Stop" Visibility="Collapsed" IsMuted="True" MediaEnded="VidLibraryPreview_MediaEnded"/>
                                </Grid>
                            </Border>
                            
                            <StackPanel x:Name="PnlSize" Visibility="Collapsed" Margin="0,0,0,15">
                                <TextBlock Text="Tamaño (Pixeles):" Margin="0,0,0,5"/>
                                <Slider x:Name="SldSize" Minimum="50" Maximum="500" Value="150"/>
                            </StackPanel>

                            <StackPanel x:Name="PnlFps" Visibility="Collapsed" Margin="0,0,0,15">
                                <TextBlock Text="Velocidad GIF (FPS):" Margin="0,0,0,5"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="-" Width="30" Click="BtnDecreaseFps_Click"/>
                                    <TextBox x:Name="TxtFps" Text="15" Width="50" TextAlignment="Center" Margin="5,0"/>
                                    <Button Content="+" Width="30" Click="BtnIncreaseFps_Click"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Content="LANZAR A PANTALLA" Click="BtnLaunchLibrary_Click" Background="#4A4AE2" Foreground="White" Padding="10" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Button Content="Eliminar" Click="BtnDeleteLibrary_Click" Background="#E24A4A" Foreground="White" Padding="5"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Smart Pets">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Grid Grid.Column="0" Margin="0,0,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Mascotas Inteligentes" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSearchPet" TextChanged="TxtSearchPet_TextChanged" Background="#1A1A24" Foreground="White" Padding="5" BorderBrush="#333"/>
                            <Button Grid.Column="1" Content="+ Agregar Config" Click="BtnAddPet_Click" Background="#2C2C3A" Foreground="White" Padding="10,5" Margin="10,0,0,0"/>
                        </Grid>
                        <ListBox x:Name="LstPets" Grid.Row="2" Background="#1A1A24" BorderBrush="#333" Foreground="White" SelectionChanged="LstPets_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <Image Source="{Binding Thumbnail}" Width="40" Height="40" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <Ellipse Width="10" Height="10" Fill="Lime" Margin="10,0,0,0" Visibility="{Binding VisibilityIndicator}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Border Grid.Column="1" Background="#1A1A24" CornerRadius="10" Padding="15">
                        <StackPanel>
                            <TextBlock x:Name="TxtSelectedPetName" Text="Ninguna seleccionada" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,10"/>
                            <Border Height="150" Background="Black" Margin="0,0,0,15">
                                <Grid>
                                    <TextBlock x:Name="TxtEmptyPetPreview" Text="Sin vista previa" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                                    <Image x:Name="ImgPetPreview" Stretch="Uniform"/>
                                </Grid>
                            </Border>
                            <Button Content="LANZAR MASCOTA" Click="BtnLaunchPet_Click" Background="#4A4AE2" Foreground="White" Padding="10" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Button Content="Eliminar" Click="BtnDeletePet_Click" Background="#E24A4A" Foreground="White" Padding="5"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Create Pet">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Create New Smart Pet Template" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    
                    <StackPanel Grid.Row="1" Margin="0,0,0,20">
                        <TextBlock Text="Pet Name:" Foreground="#AAA" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtNewPetName" Background="#1A1A24" Foreground="White" BorderBrush="#333" Padding="8" FontSize="14"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Text="Included Animations (Check the ones you will provide):" Foreground="#AAA" Margin="0,0,0,10"/>
                    
                    <WrapPanel Grid.Row="3" Margin="0,0,0,20">
                        <CheckBox x:Name="ChkAnimIdle" Content="Idle (Required)" IsChecked="True" IsEnabled="False" Foreground="White" Margin="0,0,15,10"/>
                        <CheckBox x:Name="ChkAnimWalkLeft" Content="Walk Left" Foreground="White" Margin="0,0,15,10"/>
                        <CheckBox x:Name="ChkAnimWalkRight" Content="Walk Right" Foreground="White" Margin="0,0,15,10"/>
                        <CheckBox x:Name="ChkAnimSleep" Content="Sleep" Foreground="White" Margin="0,0,15,10"/>
                        <CheckBox x:Name="ChkAnimLookScreen" Content="Look at Screen" Foreground="White" Margin="0,0,15,10"/>
                    </WrapPanel>

                    <Button Grid.Row="4" x:Name="BtnGeneratePetTemplate" Content="GENERATE PET FOLDER" Background="#4A4AE2" Foreground="White" FontWeight="Bold" Padding="15" VerticalAlignment="Top" HorizontalAlignment="Left" Click="BtnGeneratePetTemplate_Click"/>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Grid Margin="20">
                    <Button Content="Clear Cache" Click="BtnClearCache_Click" Width="150" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top" Background="#333" Foreground="White"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>